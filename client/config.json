{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "strategy": "ipv4_only",
    "independent_cache": true,
    "cache_capacity": 2048,
    "reverse_mapping": true,
    "servers": [
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      },
      {
        "tag": "remote_dns",
        "type": "https",
        "server": "1.1.1.1",
        "path": "/dns-query",
        "detour": "vless-out"
      },
      {
        "tag": "local_dns",
        "type": "local"
      }
    ],
    "rules": [
      {
        "domain": ["your-domain.com"],
        "server": "remote_dns"
      },
      {
        "domain_suffix": ["lan", "local"],
        "server": "local_dns"
      },
      {
        "query_type": "PTR",
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      {
        "query_type": ["AAAA"],
        "action": "reject"
      },
      {
        "query_type": ["A"],
        "server": "fakeip",
        "rewrite_ttl": 1
      }
    ],
    "final": "remote_dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": ["172.19.0.1/30"],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "stack": "gvisor"
    },
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "vless-out",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "uuid": "YOUR_UUID",
      "flow": "xtls-rprx-vision",
      "connect_timeout": "10s",
      "tcp_fast_open": true,
      "tls": {
        "enabled": true,
        "server_name": "your-domain.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "YOUR_PUBLIC_KEY",
          "short_id": "YOUR_SHORT_ID"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "vless-out",
    "default_domain_resolver": "remote_dns",
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_version": 6, "action": "reject" },
      {
        "ip_cidr": ["YOUR_SERVER_IP/32"],
        "action": "route",
        "outbound": "direct"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "process_name": [
          "steam.exe",
          "steamwebhelper.exe",
          "GameOverlayUI.exe",
          "EpicGamesLauncher.exe",
          "EpicWebHelper.exe",
          "Battle.net.exe",
          "nvcontainer.exe",
          "NvBrowserHelper.exe",
          "gamingservices.exe"
        ],
        "action": "route",
        "outbound": "direct"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_fakeip": true
    }
  }
}